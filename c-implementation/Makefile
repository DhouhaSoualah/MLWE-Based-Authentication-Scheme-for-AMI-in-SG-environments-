# ==========================================================
# Makefile - MLWE-AMI Desktop Prototype
# ==========================================================

# Compiler
CC = gcc

# ==========================================================
# COMPILER FLAGS
# ==========================================================

CFLAGS = -Wall -Wextra -O2 -std=c99

# ==========================================================
# OPENSSL LINKING
# ==========================================================

LDFLAGS = -lssl -lcrypto

# Windows networking compatibility
ifeq ($(OS),Windows_NT)
    LDFLAGS += -lws2_32
endif

# ==========================================================
# DIRECTORIES
# ==========================================================

SRC_DIR = src
LIB_DIR = lib
BUILD_DIR = build

# ==========================================================
# SOURCE FILES
# ==========================================================

SRCS = \
	$(SRC_DIR)/main.c \
	$(SRC_DIR)/ami_auth.c \
	$(SRC_DIR)/control_center.c \
	$(SRC_DIR)/crypto.c \
	$(SRC_DIR)/utils.c \
	$(LIB_DIR)/sha256.c \
	$(LIB_DIR)/kyber512.c

# ==========================================================
# OBJECT FILES
# ==========================================================

OBJS = $(SRCS:%.c=$(BUILD_DIR)/%.o)

# ==========================================================
# TARGET EXECUTABLE
# ==========================================================

TARGET = $(BUILD_DIR)/mlwe_ami_demo.exe

# ==========================================================
# DEFAULT TARGET
# ==========================================================

all: $(BUILD_DIR) $(TARGET)

# ==========================================================
# CREATE BUILD DIRECTORIES
# ==========================================================

$(BUILD_DIR):
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\$(SRC_DIR)" mkdir "$(BUILD_DIR)\$(SRC_DIR)"
	@if not exist "$(BUILD_DIR)\$(LIB_DIR)" mkdir "$(BUILD_DIR)\$(LIB_DIR)"

# ==========================================================
# COMPILATION
# ==========================================================

$(BUILD_DIR)/%.o: %.c
	@echo Compiling $< ...
	@$(CC) $(CFLAGS) -c $< -o $@

# ==========================================================
# LINKING
# ==========================================================

$(TARGET): $(OBJS)
	@echo Linking $(TARGET) ...
	@$(CC) $(OBJS) -o $(TARGET) $(LDFLAGS)
	@echo.
	@echo [OK] Build complete:
	@echo $(TARGET)

# ==========================================================
# CLEAN
# ==========================================================

clean:
	@if exist "$(BUILD_DIR)" rmdir /s /q "$(BUILD_DIR)"
	@echo [OK] Build directory cleaned

# ==========================================================
# RUN
# ==========================================================

run: $(TARGET)
	@$(TARGET)

# ==========================================================
# PHONY TARGETS
# ==========================================================

.PHONY: all clean run